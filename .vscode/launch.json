{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "FastAPI Backend Server",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/backend/api/main.py",
            "args": [
                "--debug",
                "--host",
                "127.0.0.1",
                "--port",
                "8000"
            ],
            "console": "integratedTerminal",
            "justMyCode": false,
            "cwd": "${workspaceFolder}/backend",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/backend:${workspaceFolder}/backend/api",
                "VIRTUAL_ENV": "${workspaceFolder}/backend/venv",
                "PATH": "${workspaceFolder}/backend/venv/bin:${env:PATH}",
                "PS1": "(venv) $ ",
                "PROMPT": "(venv) $ "
            },
            "envFile": "${workspaceFolder}/backend/.env",
            "stopOnEntry": false,
            "python": "${workspaceFolder}/backend/venv/bin/python",
            "preLaunchTask": "Activate Virtual Environment"
        },
        {
            "name": "Python: ingest.py",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/backend/api/ingest.py",
            "args": [
                "--rebuild"
            ],
            "console": "integratedTerminal",
            "justMyCode": false,
            "cwd": "${workspaceFolder}/backend",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/backend",
                "VIRTUAL_ENV": "${workspaceFolder}/backend/venv",
                "PATH": "${workspaceFolder}/backend/venv/bin:${env:PATH}",
                "PS1": "(venv) ${env:PS1}"
            },
            "envFile": "${workspaceFolder}/backend/.env",
            "python": "${workspaceFolder}/backend/venv/bin/python",
            "preLaunchTask": "Activate Virtual Environment"
        },
        {
            "name": "Freshdesk Collection Script",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/backend/freshdesk/run_collection.py",
            "console": "integratedTerminal",
            "justMyCode": false,
            "cwd": "${workspaceFolder}/backend",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/backend",
                "VIRTUAL_ENV": "${workspaceFolder}/backend/venv",
                "PATH": "${workspaceFolder}/backend/venv/bin:${env:PATH}",
                "PS1": "(venv) ${env:PS1}"
            },
            "envFile": "${workspaceFolder}/backend/.env",
            "python": "${workspaceFolder}/backend/venv/bin/python",
            "preLaunchTask": "Activate Virtual Environment"
        },
        {
            "name": "Freshdesk Collection - Full Collection",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/backend/freshdesk/run_collection.py",
            "args": [
                "--full-collection"
            ],
            "console": "integratedTerminal",
            "justMyCode": false,
            "cwd": "${workspaceFolder}/backend",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/backend",
                "VIRTUAL_ENV": "${workspaceFolder}/backend/venv",
                "PATH": "${workspaceFolder}/backend/venv/bin:${env:PATH}",
                "PS1": "(venv) ${env:PS1}"
            },
            "envFile": "${workspaceFolder}/backend/.env",
            "python": "${workspaceFolder}/backend/venv/bin/python",
            "preLaunchTask": "Activate Virtual Environment"
        },
        {
            "name": "Freshdesk Collection - Quick Test",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/backend/freshdesk/run_collection.py",
            "args": [
                "--full-collection",
                "--start-date",
                "2025-03-01"
            ],
            "console": "integratedTerminal",
            "justMyCode": false,
            "cwd": "${workspaceFolder}/backend",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/backend",
                "VIRTUAL_ENV": "${workspaceFolder}/backend/venv",
                "PATH": "${workspaceFolder}/backend/venv/bin:${env:PATH}",
                "PS1": "(venv) ${env:PS1}"
            },
            "envFile": "${workspaceFolder}/backend/.env",
            "python": "${workspaceFolder}/backend/venv/bin/python",
            "preLaunchTask": "Activate Virtual Environment"
        },
        {
            "name": "Freshdesk Collection - Resume",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/backend/freshdesk/run_collection.py",
            "args": [
                "--resume"
            ],
            "console": "integratedTerminal",
            "justMyCode": false,
            "cwd": "${workspaceFolder}/backend",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/backend",
                "VIRTUAL_ENV": "${workspaceFolder}/backend/venv",
                "PATH": "${workspaceFolder}/backend/venv/bin:${env:PATH}",
                "PS1": "(venv) ${env:PS1}"
            },
            "envFile": "${workspaceFolder}/backend/.env",
            "python": "${workspaceFolder}/backend/venv/bin/python",
            "preLaunchTask": "Activate Virtual Environment"
        },
        {
            "name": "Test LLM Router",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/backend/core/llm_router.py",
            "console": "integratedTerminal",
            "justMyCode": false,
            "cwd": "${workspaceFolder}/backend",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/backend",
                "VIRTUAL_ENV": "${workspaceFolder}/backend/venv",
                "PATH": "${workspaceFolder}/backend/venv/bin:${env:PATH}",
                "PS1": "(venv) ${env:PS1}"
            },
            "envFile": "${workspaceFolder}/backend/.env",
            "python": "${workspaceFolder}/backend/venv/bin/python",
            "preLaunchTask": "Activate Virtual Environment"
        },
        {
            "name": "Python: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "justMyCode": false,
            "cwd": "${workspaceFolder}/backend",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/backend",
                "VIRTUAL_ENV": "${workspaceFolder}/backend/venv",
                "PATH": "${workspaceFolder}/backend/venv/bin:${env:PATH}",
                "PS1": "(venv) ${env:PS1}"
            },
            "python": "${workspaceFolder}/backend/venv/bin/python",
            "preLaunchTask": "Activate Virtual Environment"
        },
        {
            "name": "FDK in Freshdesk (실제 환경)",
            "type": "chrome",
            "request": "launch",
            "url": "https://wedosoft.freshdesk.com/a/tickets/12092?dev=true",
            "webRoot": "${workspaceFolder}/frontend/app",
            "sourceMapPathOverrides": {
                "webpack:///./*": "${webRoot}/*",
                "webpack:///src/*": "${webRoot}/*",
                "webpack:///*": "*",
                "https://localhost:10001/*": "${webRoot}/*",
                "/./*": "${webRoot}/*",
                "/static/js/*": "${webRoot}/*",
                "/app/*": "${webRoot}/*",
                "*": "${webRoot}/*"
            },
            "userDataDir": "${workspaceFolder}/.vscode/chrome-debug-profile",
            "runtimeArgs": [
                "--allow-running-insecure-content",
                "--disable-features=VizDisplayCompositor",
                "--remote-debugging-port=9222"
            ],
            "trace": true,
            "disableNetworkCache": true,
            "sourceMaps": true,
            "showAsyncStacks": true,
            "smartStep": true,
            "skipFiles": [
                "<node_internals>/**",
                "**/node_modules/**",
                "${workspaceFolder}/frontend/node_modules/**"
            ]
        }
    ]
}